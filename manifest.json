{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.5",
  "description": "__MSG_extDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "lib/browser-polyfill.min.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Anti Brainrot",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "mascot.png"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "anti-brainrot@lovespark.suite",
      "data_collection_permissions": {
        "required": false,
        "is_exempt": true,
        "justification": "This extension does not collect, transmit, or store any user data."
      }
    }
  },
  "default_locale": "en"
}
